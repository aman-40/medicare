generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACIST
  OPTOMETRIST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id          String   @id @default(cuid())
  patientCode String   @unique // Auto Generated
  name        String
  age         Int?
  gender      String?
  phone       String?
  address     String?
  occupation  String?
  createdAt   DateTime @default(now())

  queues       Queue[]
  eyeReports   EyeReport[]
  glassOrders  GlassOrder[]
  invoices     Invoice[]
}

model Queue {
  id          String   @id @default(cuid())
  tokenNumber Int
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  status      String   @default("Waiting") // Waiting, Serving, Completed
  createdAt   DateTime @default(now())
}

model EyeReport {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  
  rightSph  String?
  rightCyl  String?
  rightAxis String?
  leftSph   String?
  leftCyl   String?
  leftAxis  String?
  addPower  String?
  notes     String?
  reportData Json?

  createdAt DateTime @default(now())
}

model Frame {
  id           String  @id @default(cuid())
  name         String
  brand        String
  modelNo      String?
  color        String?
  stock        Int     @default(0)
  purchasePrice Float  @default(0)
  sellingPrice  Float  @default(0)

  glassOrders GlassOrder[]
}

model Lens {
  id           String @id @default(cuid())
  type         String // Single Vision, Progressive, etc.
  brand        String
  purchasePrice Float  @default(0)
  sellingPrice  Float  @default(0)

  glassOrders GlassOrder[]
}

model GlassOrder {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  frameId     String
  frame       Frame    @relation(fields: [frameId], references: [id])
  lensId      String
  lens        Lens     @relation(fields: [lensId], references: [id])
  
  status      String   @default("Pending") // Pending, In Progress, Ready, Delivered
  totalAmount Float
  deliveryDate DateTime?

  createdAt   DateTime @default(now())
}

model Medicine {
  id            String   @id @default(cuid())
  name          String
  company       String
  batchNo       String
  purchasePrice Float
  sellingPrice  Float
  stock         Int
  expiryDate    DateTime
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  
  createdAt     DateTime @default(now())
}

model Supplier {
  id        String @id @default(cuid())
  name      String
  phone     String
  address   String?
  gstNumber String?

  medicines Medicine[]
}

model Invoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])
  patientName String?
  subtotal    Float    @default(0)
  gstAmount   Float    @default(0)
  totalAmount Float
  createdAt   DateTime @default(now())

  items       InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productName String
  quantity    Int
  rate        Float
  amount      Float
}
