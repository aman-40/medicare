generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACIST
  OPTOMETRIST
  CUSTOMER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   Patient?
  doctor    Doctor?
}

model Patient {
  id          String   @id @default(cuid())
  patientCode String   @unique // Auto Generated
  name        String
  age         Int?
  gender      String?
  phone       String?
  address     String?
  occupation  String?
  feeAmount   Float?
  paymentMethod String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
  userId      String?  @unique

  queues       Queue[]
  eyeReports   EyeReport[]
  glassOrders  GlassOrder[]
  invoices     Invoice[]
  appointments Appointment[]
}

model Doctor {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  specialization String?
  availability   String?

  appointments   Appointment[]
}

model Appointment {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  date        DateTime
  
  queue       Queue?
  
  createdAt   DateTime @default(now())
}

model Queue {
  id          String   @id @default(cuid())
  tokenNumber Int
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  status        String       @default("Waiting") // Waiting, Serving, Completed
  createdAt     DateTime     @default(now())
}

model EyeReport {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  
  rightSph  String?
  rightCyl  String?
  rightAxis String?
  leftSph   String?
  leftCyl   String?
  leftAxis  String?
  addPower  String?
  notes     String?
  reportData Json?

  createdAt DateTime @default(now())
}

model Frame {
  id           String  @id @default(cuid())
  name         String
  brand        String
  modelNo      String?
  color        String?
  stock        Int     @default(0)
  purchasePrice Float  @default(0)
  sellingPrice  Float  @default(0)
  material      String?
  imageUrl      String?

  glassOrders GlassOrder[]
}

model Lens {
  id           String @id @default(cuid())
  name         String
  type         String // Single Vision, Progressive, etc.
  brand        String
  material     String?
  purchasePrice Float  @default(0)
  sellingPrice  Float  @default(0)

  glassOrders GlassOrder[]
}

model GlassOrder {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  frameId     String
  frame       Frame    @relation(fields: [frameId], references: [id])
  lensId      String
  lens        Lens     @relation(fields: [lensId], references: [id])
  
  status      String   @default("Pending") // Pending, In Progress, Ready, Delivered
  totalAmount Float
  deliveryDate DateTime?

  createdAt   DateTime @default(now())
}

model Medicine {
  id            String   @id @default(cuid())
  name          String
  brandName     String?
  genericName   String?
  company       String
  batchNo       String
  purchasePrice Float
  sellingPrice  Float
  gstPercent    Float    @default(0)
  stock         Int
  expiryDate    DateTime
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  invoiceItems  InvoiceItem[]
  
  createdAt     DateTime @default(now())
}

model Supplier {
  id        String @id @default(cuid())
  name      String
  phone     String
  address   String?
  gstNumber String?

  medicines Medicine[]
}

model Invoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])
  patientName String?
  mobileNumber String?
  subtotal    Float    @default(0)
  gstAmount   Float    @default(0)
  discount    Float    @default(0)
  grandTotal  Float    @default(0)
  totalAmount Float
  paymentMethod String @default("CASH")
  status      String   @default("Pending")
  createdAt   DateTime @default(now())

  items       InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  medicineId  String?
  medicine    Medicine? @relation(fields: [medicineId], references: [id])
  productName String
  quantity    Int
  rate        Float
  gst         Float   @default(0)
  amount      Float
  total       Float   @default(0)
}
